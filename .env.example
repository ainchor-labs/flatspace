# Copy to `.env` and fill in before running `docker compose up`.

# Signing secret for auth cookies (JWT). Use a long, random value, e.g.:
#   openssl rand -hex 32
# If unset, the server uses a known insecure dev secret (tokens are forgeable).
FLATSPACE_JWT_SECRET=

# Optional: maximum upload size in bytes (default 1 GiB).
# FLATSPACE_MAX_UPLOAD=1073741824
